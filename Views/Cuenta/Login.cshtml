@model LoginViewModel
@{
    ViewData["Title"] = "Iniciar sesión";
    var esDni = Model.TipoDocumento != "CE";
}

<div class="lienzo-andes d-flex flex-column align-items-center justify-content-center py-5">

    <div class="tarjeta-login card border-0 shadow-sm">
        <div class="card-body p-4">
            <form asp-action="Login" method="post" id="form-login" novalidate>
                <input type="hidden" asp-for="TipoDocumento" id="tipoDocumento" />

                <div class="selector-doc d-flex mb-4" role="tablist">
                    <button type="button" class="btn-doc @(esDni ? "activo" : "")" data-tipo="DNI">DNI</button>
                    <button type="button" class="btn-doc @(!esDni ? "activo" : "")" data-tipo="CE">CE</button>
                </div>

                <div class="mb-3">
                    <label asp-for="Usuario" class="form-label">Usuario</label>
                    <div class="input-group campo @(Model.ErrorUsuario != null ? "campo-error" : "")">
                        <span class="input-group-text bg-white">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="#6c757d"><path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6m4 6H4s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1"/></svg>
                        </span>
                        <input asp-for="Usuario" class="form-control border-start-0 ps-0" placeholder="Ingresar usuario"
                               autocomplete="username" maxlength="@(esDni ? 8 : 9)" />
                    </div>
                    @if (Model.ErrorUsuario != null)
                    {
                        <div class="mensaje-error"><span class="punto-error">&#8856;</span> @Model.ErrorUsuario</div>
                    }
                    <span asp-validation-for="Usuario" class="mensaje-error d-block"></span>
                </div>

                <div class="mb-2">
                    <label asp-for="Contrasena" class="form-label">Contraseña</label>
                    <div class="input-group campo @(Model.ErrorContrasena != null ? "campo-error" : "")">
                        <span class="input-group-text bg-white">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="#6c757d"><path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2m3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2"/></svg>
                        </span>
                        <input asp-for="Contrasena" class="form-control border-start-0 border-end-0 ps-0"
                               placeholder="Ingresar contraseña" autocomplete="current-password" />
                        <button type="button" class="input-group-text bg-white boton-ojo" id="toggleContrasena" tabindex="-1" aria-label="Mostrar contraseña">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="#6c757d"><path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M1.173 8a13 13 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5s3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5s-3.879-1.168-5.168-2.457A13 13 0 0 1 1.172 8z"/><path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0"/></svg>
                        </button>
                    </div>
                    @if (Model.ErrorContrasena != null)
                    {
                        <div class="mensaje-error"><span class="punto-error">&#8856;</span> @Model.ErrorContrasena</div>
                    }
                    <span asp-validation-for="Contrasena" class="mensaje-error d-block"></span>
                </div>

                <a href="#" class="enlace-azul small">¿Olvidó su contraseña?</a>

                <button type="submit" class="btn btn-primario w-100 mt-4" id="btnIngresar">Ingresar</button>
            </form>
        </div>
    </div>

    <div class="tarjeta-ayuda card border-0 shadow-sm mt-3">
        <div class="card-body d-flex align-items-center gap-3 py-3">
            <span class="icono-soporte">
                <svg width="34" height="34" viewBox="0 0 16 16" fill="#2E6FE5"><path d="M8 1a5 5 0 0 0-5 5v1h1a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V6a6 6 0 1 1 12 0v6a2.5 2.5 0 0 1-2.5 2.5H9.366a1 1 0 0 1-.866.5h-1a1 1 0 1 1 0-2h1a1 1 0 0 1 .866.5H11.5A1.5 1.5 0 0 0 13 12h-1a1 1 0 0 1-1-1V8a1 1 0 0 1 1-1h1V6a5 5 0 0 0-5-5"/></svg>
            </span>
            <span class="small">¿Necesita ayuda?, <a href="#" class="enlace-azul">contacte con el área de soporte.</a></span>
        </div>
    </div>
</div>

@if (TempData["SesionExpirada"] is string mensajeExpiracion)
{
    <div class="aviso-expiracion alert d-flex align-items-start gap-2 shadow-sm" role="alert">
        <svg class="mt-1 flex-shrink-0" width="16" height="16" viewBox="0 0 16 16" fill="#2E6FE5"><path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16m.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.47l-.451-.081.082-.381 2.29-.287zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2"/></svg>
        <span class="small">@mensajeExpiracion</span>
    </div>
}
