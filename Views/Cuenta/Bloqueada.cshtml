@{
    ViewData["Title"] = "Cuenta bloqueada";
    var minutos = (int)(ViewBag.Minutos ?? 15);
    var soporteNotificado = ViewBag.SoporteNotificado == true;
}

<div class="lienzo-andes d-flex align-items-center justify-content-center py-5">
    <div class="tarjeta-bloqueo card border-0 shadow-sm text-center">
        <div class="card-body p-5">
            <div class="circulo-icono mx-auto mb-3">
                <svg width="42" height="42" viewBox="0 0 16 16" fill="#2E6FE5"><path d="M11 5a3 3 0 1 1-6 0 3 3 0 0 1 6 0m-9 8c0 1 1 1 1 1h5.256A4.5 4.5 0 0 1 8 12.5a4.5 4.5 0 0 1 1.544-3.393Q8.844 9.002 8 9c-5 0-6 3-6 4m7 .5a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0m3.5-2a1 1 0 0 0-1 1v.5h2V12.5a1 1 0 0 0-1-1m-1.5 2a.5.5 0 0 0-.5.5v1.5a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5V14a.5.5 0 0 0-.5-.5z"/></svg>
            </div>
            <h5 class="fw-bold mb-3">Cuenta bloqueada temporalmente</h5>
            <p class="text-secondary small mb-4">
                Has excedido el número máximo de intentos fallidos (5).
                Por seguridad, tu cuenta ha sido bloqueada durante @minutos minutos.
                Intente nuevamente más tarde.
            </p>
            @if (soporteNotificado)
            {
                <div class="alert alert-info small text-start">Se notificó al área de soporte técnico para revisar el desbloqueo de la cuenta.</div>
            }
            <form asp-action="NotificarSoporte" method="post" class="mb-3">
                <button type="submit" class="btn btn-primario px-4">Notificar soporte técnico</button>
            </form>
            <a asp-action="Login" class="enlace-azul small">Volver al inicio</a>
        </div>
    </div>
</div>
