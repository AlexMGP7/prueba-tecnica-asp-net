@inject Microsoft.Extensions.Configuration.IConfiguration Config
@{
    var autenticado = User.Identity?.IsAuthenticated == true;
    var minutosSesion = Config.GetValue("Seguridad:MinutosSesion", 20);
    var avisoSegundos = Config.GetValue("Seguridad:SegundosAvisoExpiracion", 60);
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CEPLAN</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="pagina" data-autenticado="@(autenticado ? "1" : "0")"
      data-sesion-minutos="@minutosSesion" data-aviso-segundos="@avisoSegundos">

    <header class="barra-roja d-flex align-items-center justify-content-between px-4">
        <a class="logo-ceplan text-decoration-none" href="/">
            <span class="logo-texto">CEPLAN<span class="logo-estrella">★</span></span>
            <span class="logo-sub">Centro Nacional de Planeamiento Estratégico</span>
        </a>
        <div class="d-flex align-items-center gap-3">
            @if (autenticado)
            {
                <span class="icono-header" title="Ayuda">?</span>
                <span class="icono-header" title="Notificaciones">
                    <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor"><path d="M8 16a2 2 0 0 0 2-2H6a2 2 0 0 0 2 2m.995-14.901a1 1 0 1 0-1.99 0A5 5 0 0 0 3 6c0 1.098-.5 6-2 7h14c-1.5-1-2-5.902-2-7a5 5 0 0 0-4.005-4.901"/></svg>
                </span>
                <div class="d-flex align-items-center gap-2 text-white">
                    <svg width="26" height="26" viewBox="0 0 16 16" fill="currentColor"><path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6m4 6H4s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1"/></svg>
                    <div class="lh-sm">
                        <div class="fw-semibold small">@User.Identity!.Name</div>
                        <div class="rol-header">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</div>
                    </div>
                </div>
                <form asp-controller="Cuenta" asp-action="Logout" method="post" class="m-0" id="form-logout">
                    <input type="hidden" name="expirada" value="false" id="logout-expirada" />
                    <button type="submit" class="btn btn-sm btn-outline-light" title="Cerrar sesión">Salir</button>
                </form>
            }
            else
            {
                <span class="icono-header" title="Ayuda">?</span>
            }
        </div>
    </header>

    <main class="contenido">
        @RenderBody()
    </main>

    <footer class="pie d-flex justify-content-end align-items-center pe-4">
        <div class="d-flex pie-logos align-items-stretch">
            <div class="pie-peru d-flex align-items-center gap-1 px-2">
                <img class="pie-escudo" src="~/img/escudo-peru.png" alt="Escudo del Perú" />
                <span>PERÚ</span>
            </div>
            <div class="pie-pcm px-2 d-flex align-items-center">Presidencia<br />del Consejo de<br />Ministros</div>
            <div class="pie-ceplan px-2 d-flex align-items-center">Centro Nacional de<br />Planeamiento<br />Estratégico</div>
        </div>
    </footer>

    @if (autenticado)
    {
        <!-- Modal de aviso de expiración de sesión por inactividad -->
        <div class="modal fade" id="modalSesion" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content p-2">
                    <div class="modal-body">
                        <div class="d-flex gap-3">
                            <div class="icono-alerta">
                                <svg width="28" height="28" viewBox="0 0 16 16" fill="#F0A92D"><path d="M7.938 2.016A.13.13 0 0 1 8.002 2a.13.13 0 0 1 .063.016.15.15 0 0 1 .054.057l6.857 11.667c.036.06.035.124.002.183a.2.2 0 0 1-.054.06.1.1 0 0 1-.066.017H1.146a.1.1 0 0 1-.066-.017.2.2 0 0 1-.054-.06.18.18 0 0 1 .002-.183L7.884 2.073a.15.15 0 0 1 .054-.057m1.044-.45a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767z"/><path d="M7.002 12a1 1 0 1 1 2 0 1 1 0 0 1-2 0M7.1 5.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0z"/></svg>
                            </div>
                            <div class="flex-grow-1">
                                <h5 class="fw-bold mb-2">Su sesión está a punto de expirar</h5>
                                <p class="mb-3 text-secondary">
                                    Por seguridad, su sesión expirará en <span id="segundosRestantes" class="fw-semibold">60</span> segundos.
                                    Para continuar, seleccione "Extender sesión"
                                </p>
                                <div class="text-end">
                                    <button type="button" id="btnExtenderSesion" class="btn btn-ambar fw-semibold">Extender sesión</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
